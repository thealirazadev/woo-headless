# Base URL of your WooCommerce store, including protocol, no trailing slash.
# Used to build wc/v3 REST requests and the checkout redirect URL. Server-only.
WOOCOMMERCE_STORE_URL=https://store.example.com

# WooCommerce REST API consumer key (read access is enough). Server-only, never exposed to the browser.
WOOCOMMERCE_CONSUMER_KEY=ck_0000000000000000000000000000000000000000

# WooCommerce REST API consumer secret. Server-only, never exposed to the browser.
WOOCOMMERCE_CONSUMER_SECRET=cs_0000000000000000000000000000000000000000

# Public store name shown in the UI header and page titles. Safe to expose to the client.
NEXT_PUBLIC_STORE_NAME=Example Store
